# Ollama endpoint — override for Docker (use host.docker.internal:11434)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# Claude API (for cloud honeypot variant)
ANTHROPIC_API_KEY=

# Gemini (for attacker agent + WAT tools)
GEMINI_API_KEY=

# Honeypot config
HONEYPOT_PORT=2222
MAX_TURNS=25
